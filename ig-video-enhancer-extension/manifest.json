{
  "manifest_version": 3,
  "name": "FALO Instagram Video Enhancer",
  "version": "1.0.1",
  "description": "為 Instagram Reels 與 Stories 加入影片進度條、播放/暫停控制、鍵盤快捷鍵、音量控制和播放速度選項。Adds video progress bars, play/pause controls, keyboard shortcuts, volume controls, and playback speed options for Instagram Reels and Stories. (Falo x Force Cheng 2026/6/8)",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ]
}
